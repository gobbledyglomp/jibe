[Unit]
Description=ydotool daemon — required for Jibe presentation remote on Wayland
Documentation=https://github.com/ReimuNotMoe/ydotool
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/ydotoold
Restart=on-failure
RestartSec=3
# Requires read/write access to /dev/uinput — user must be in the 'input' group
# (install.sh prints instructions). Optional: sudo modprobe uinput

[Install]
WantedBy=default.target
